# Supabase — pegue estes valores em https://supabase.com/dashboard
# Settings -> API -> Project URL e anon/public key
# Estas chaves sao publicas por design (vao pro bundle do front-end).
# A SEGURANCA depende das policies RLS no banco, NAO destas chaves.
VITE_SUPABASE_PROJECT_ID="seu-project-id"
VITE_SUPABASE_PUBLISHABLE_KEY="sua-anon-key"
VITE_SUPABASE_URL="https://seu-project-id.supabase.co"
